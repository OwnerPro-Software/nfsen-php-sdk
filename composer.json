{
  "name": "ownerpro/nfsen",
  "description": "Pacote Laravel para emissão de NFSe Nacional",
  "license": "MIT",
  "homepage": "https://github.com/OwnerPro-Software/nfsen",
  "keywords": [
    "nfse",
    "nota-fiscal",
    "nota-fiscal-servico",
    "nfse-nacional",
    "laravel",
    "php",
    "xml",
    "certificado-digital",
    "prefeitura"
  ],
  "support": {
    "issues": "https://github.com/OwnerPro-Software/nfsen/issues",
    "source": "https://github.com/OwnerPro-Software/nfsen"
  },
  "require": {
    "php": "^8.2",
    "nfephp-org/sped-common": "^5.1",
    "illuminate/http": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/contracts": "^11.0|^12.0",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-zlib": "*",
    "ext-openssl": "*",
    "ext-mbstring": "*",
    "ext-libxml": "*"
  },
  "require-dev": {
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest-plugin-type-coverage": "^3.6",
    "rector/rector": "^2.3",
    "driftingly/rector-laravel": "^2.1",
    "larastan/larastan": "^3.9",
    "laravel/pint": "^1.27",
    "roave/security-advisories": "dev-latest",
    "vimeo/psalm": "^6.15"
  },
  "autoload": {
    "psr-4": {
      "OwnerPro\\Nfsen\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OwnerPro\\Nfsen\\Tests\\": "tests/"
    },
    "files": [
      "tests/helpers.php"
    ]
  },
  "scripts": {
    "test": "./vendor/bin/pest --coverage --min=100",
    "test:types": "./vendor/bin/pest --type-coverage --min=100",
    "test:mutate": "./vendor/bin/pest --mutate",
    "analyse": "./vendor/bin/phpstan analyse",
    "psalm": "./vendor/bin/psalm --taint-analysis",
    "rector": "./vendor/bin/rector --dry-run",
    "format": "./vendor/bin/pint",
    "quality": [
      "@test",
      "@test:types",
      "@analyse",
      "@psalm",
      "@rector",
      "@format"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "laravel": {
      "providers": ["OwnerPro\\Nfsen\\NfseNacionalServiceProvider"]
    }
  }
}
