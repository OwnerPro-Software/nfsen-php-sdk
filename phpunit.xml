<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="vendor/autoload.php" colors="true">
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
        <exclude>
            <!--
                Pure data DTOs: readonly classes com apenas parâmetros promovidos
                e corpo de construtor vazio. Não têm lógica para testar, e pcov/xdebug
                não rastreiam construtores sem statements executáveis.
            -->
            <directory>src/Danfse/Data</directory>
        </exclude>
    </source>
</phpunit>
